<view class="container" wx:if="{{items.length}}">
  <view class="line" wx:for="{{items}}" wx:key="id">
    <view class="line__img">{{item.emoji}}</view>
    <view class="line__info">
      <view class="line__name">{{item.name}}</view>
      <view class="price">¥{{item.price}}</view>
    </view>
    <view class="stepper">
      <view class="step" bindtap="dec" data-id="{{item.id}}">−</view>
      <text class="qtynum">{{item.qty}}</text>
      <view class="step" bindtap="inc" data-id="{{item.id}}">+</view>
    </view>
    <view class="del" bindtap="remove" data-id="{{item.id}}">×</view>
  </view>
</view>

<view class="empty" wx:else>
  <text class="muted">购物车是空的</text>
</view>

<view class="checkout" wx:if="{{items.length}}">
  <text>合计 <text class="price">¥{{subtotal}}</text></text>
  <view class="btn checkout__btn" bindtap="checkout">结算</view>
</view>
