.grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.item { width: 48%; margin-bottom: 24rpx; }
.item__img { height: 220rpx; display: flex; align-items: center; justify-content: center; font-size: 90rpx; background: linear-gradient(160deg, #e7e0d3, #cfc7b6); }
.item__body { padding: 16rpx 18rpx 20rpx; }
.item__name { font-size: 28rpx; font-weight: 500; }
.item__row { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx; }
.price { font-size: 30rpx; }
.add { width: 52rpx; height: 52rpx; line-height: 48rpx; text-align: center; border-radius: 50%; background: #2e8b57; color: #fff; font-size: 36rpx; }
