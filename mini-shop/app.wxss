page { background: #f6f8fa; color: #26251f; font-family: -apple-system, "Helvetica Neue", sans-serif; }
.container { padding: 24rpx; }
.btn { background: #2e8b57; color: #fff; border-radius: 999rpx; font-size: 28rpx; padding: 16rpx 0; text-align: center; }
.btn--ghost { background: #fff; color: #2e8b57; border: 1rpx solid #2e8b57; }
.muted { color: #8a877d; font-size: 24rpx; }
.price { color: #2e8b57; font-weight: 600; }
.card { background: #fff; border-radius: 16rpx; overflow: hidden; }
